<div class="task-detail-page" data-controller="task-detail">
  <div class="container task-container">

    <div class="d-flex justify-content-end mb-2">
      <%= link_to "← Back", root_path, class: "task-back-link" %>
    </div>

    <%# ── MAIN LAYOUT ── %>
    <div class="task-layout">

      <%# ── LEFT COLUMN ── %>
      <div class="task-main">

        <%# ── BREADCRUMB ── %>
        <div class="task-breadcrumb">
          <span class="task-badge task-badge--urgent">DUE IN 2 DAYS</span>
          <% if @task.pillar %>
            <span class="tag tag-pillar--<%= @task.pillar.slug %>"><%= @task.pillar.name %></span>
          <% end %>
          <span class="breadcrumb__divider">·</span>
          <span class="breadcrumb__position">Task <%= @task_position %> of <%= @pillar_tasks_count %></span>
        </div>

        <%# ── HEADER ── %>
        <div class="task-header">
          <div class="task-header__text">
            <h1 class="task-title"><%= @task.name %></h1>
            <p class="task-description"><%= @task.description %></p>
          </div>
          <span class="autosave" data-task-detail-target="autosave">✓ Saved</span>
        </div>

        <%# ── WHY THIS MATTERS ── %>
        <div class="task-why">
          <svg class="task-why__icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="8"/>
            <line x1="12" y1="12" x2="12" y2="16"/>
          </svg>
          <p>
            <strong>Good to know:</strong>
            <%= @task.why_it_matters %>
          </p>
        </div>

        <%# ── STEPS SECTION ── %>
        <div class="task-steps">

          <%# ── STEPS HEADER ── %>
          <% completed_steps = @checklist_items.select { |i| @user_checklist_items[i.id]&.completed }.count %>
          <div class="task-steps__header">
            <span class="task-steps__label">Applying for Public Health Insurance</span>
            <span class="task-steps__count" data-task-detail-target="stepCount">
              <% if completed_steps == @checklist_items.count %>
                All steps complete!
              <% else %>
                Step <%= completed_steps + 1 %> of <%= @checklist_items.count %>
              <% end %>
            </span>
          </div>

          <%# ── STEPS LIST ── %>
          <div class="task-steps__list" data-task-detail-target="stepsList">
            <% @checklist_items.each_with_index do |item, index| %>
              <% progress  = @user_checklist_items[item.id] %>
              <% completed = progress&.completed %>
              <% is_active = !completed && @checklist_items.select { |i| @user_checklist_items[i.id]&.completed }.count == index %>

              <div class="step <%= completed ? 'step--completed' : '' %> <%= is_active ? 'step--active' : '' %> <%= !completed && !is_active ? 'step--locked' : '' %>"
                   data-task-detail-target="step"
                   data-completed="<%= completed %>">

                <%# ── STEP NUMBER ── %>
                <% if completed %>
                  <%# Completed: number circle becomes clickable undo button %>
                  <div class="step__number step__number--done">
                    <%= button_to user_checklist_item_path(item),
                        method: :patch,
                        form: { data: { turbo: "false" } },
                        class: "step__undo-btn",
                        title: "Mark as incomplete" do %>
                      <span class="step__check">✓</span>
                    <% end %>
                  </div>
                <% else %>
                  <div class="step__number">
                    <span><%= index + 1 %></span>
                  </div>
                <% end %>

                <%# ── STEP CONTENT ── %>
                <div class="step__content">
                  <div class="step__header">

                    <%# ── CHECKBOX (all incomplete steps) ── %>
                    <% unless completed %>
                      <%= button_to user_checklist_item_path(item),
                          method: :patch,
                          form: {
                            class: "step__checkbox-form",
                            data: {
                              action: "submit->task-detail#completeStep",
                              turbo: "false"
                            }
                          },
                          class: "step__checkbox" do %>
                        <span class="step__checkbox-inner"></span>
                      <% end %>
                    <% end %>

                    <h3 class="step__title"><%= item.title %></h3>
                    <% if is_active %>
                      <span class="task-badge task-badge--action">Action required</span>
                    <% end %>

                  </div>

                  <p class="step__description"><%= item.description %></p>

                  <%# ── ACTIVE STEP EXTRAS ── %>
                  <% if is_active %>
                    <div class="step__footer">
                      <span class="step__files">📎 1 Attached File</span>
                      <a href="#" class="step__reminder">🕐 Set Reminder</a>
                    </div>
                  <% end %>

                  <%# ── MARK COMPLETE TOGGLE (active fallback) ── %>
                  <% if !completed && is_active %>
                    <%= button_to user_checklist_item_path(item),
                        method: :patch,
                        class: "step__toggle",
                        data: { "task-detail-target": "toggleBtn" } do %>
                      Mark complete
                    <% end %>
                  <% end %>

                </div>
              </div>
            <% end %>
          </div>

        </div>

        <%# ── SKIP FALLBACK ── %>
        <div class="task-skip">
          <a href="#" class="task-skip__link"></a>
        </div>

      </div>

      <%# ── RIGHT COLUMN ── %>
      <div class="task-sidebar">

        <%# ── EXPERT TIPS — shown first, aligned with Good to Know div ── %>
        <div class="expert-tips">
          <span class="expert-tips__label">⚡ EXPERT TIPS</span>
          <% if @task.expert_tips.present? %>
            <% @task.expert_tips.each do |tip| %>
              <div class="expert-tips__item">
                <h4><%= tip["title"] %></h4>
                <p><%= tip["body"] %></p>
              </div>
            <% end %>
          <% else %>
            <div class="expert-tips__item">
              <p style="color: rgba(255,255,255,0.5); font-size: 13px;">Expert tips are being generated…</p>
            </div>
          <% end %>
        </div>

        <%# ── QUICK GUIDES ── %>
        <div class="quick-guides">
          <div class="quick-guides__header">
            <h3>Quick Guides</h3>
            <a href="#">↗</a>
          </div>
          <div class="quick-guides__list">
            <a href="#" class="quick-guide__item">
              <span class="quick-guide__icon quick-guide__icon--pdf">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </span>
              <div>
                <p class="quick-guide__title">Public vs Private Insurance</p>
                <p class="quick-guide__meta">PDF • 2.4 MB</p>
              </div>
            </a>
            <a href="#" class="quick-guide__item">
              <span class="quick-guide__icon quick-guide__icon--doc">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                </svg>
              </span>
              <div>
                <p class="quick-guide__title">Employer Notification Template</p>
                <p class="quick-guide__meta">DOCX • 18 KB</p>
              </div>
            </a>
            <a href="#" class="quick-guide__item">
              <span class="quick-guide__icon quick-guide__icon--link">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7A9E1F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                </svg>
              </span>
              <div>
                <p class="quick-guide__title">Official Subsidy Calculator</p>
                <p class="quick-guide__meta">External Link</p>
              </div>
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>

  <%# ── COMPLETION OVERLAY ── %>
  <div class="completion-overlay" data-task-detail-target="completionOverlay">
    <div class="completion-overlay__card">
      <div class="completion-overlay__icon">✓</div>
      <h2 class="completion-overlay__title">Task Completed! 🎉</h2>
      <p class="completion-overlay__message"><%= @task.name %> is done and dusted.</p>
      <p class="completion-overlay__sub">Heading back to your dashboard..</p>
      <div class="completion-overlay__bar">
        <div class="completion-overlay__bar-fill"></div>
      </div>
    </div>
  </div>

</div>
