<% content_for :meta_title, "Landed | #{@task.name}" %>

<style>
  .task-detail-page { background: #F7F7FB; min-height: 100vh; }
  .task-title { font-size: 20px !important; font-weight: 600 !important; letter-spacing: -0.02em; }
  .task-description { font-size: 14px !important; }
  .task-why { border-radius: 12px !important; font-size: 14px !important; }
  .task-why p { font-size: 14px !important; margin: 0 !important; }
  .task-badge { font-size: 12px !important; border-radius: 20px !important; }
  .expert-tips { border-radius: 16px !important; }
  .expert-tips__item h4 { font-size: 14px !important; }
  .expert-tips__item p { font-size: 14px !important; }
  .quick-guides { border-radius: 16px !important; }
  .quick-guide__item { border-radius: 12px !important; }
  .quick-guide__title { font-size: 14px !important; }
  .quick-guide__meta { font-size: 12px !important; }
  .task-steps__label { font-size: 14px !important; }
  .step { border-radius: 12px !important; padding: 0.9rem !important; }
  .step__title { font-size: 14px !important; }
  .step--locked .step__unlock-hint {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
    font-size: 12px;
    color: #9ca3af;
    font-weight: 500;
  }
  .step--locked .step__unlock-hint svg { flex-shrink: 0; }
</style>

