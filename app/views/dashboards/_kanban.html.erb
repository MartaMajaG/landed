<% completed_tasks = local_assigns.fetch(:completed_tasks, nil) %>

<% if completed_tasks %>

  <%# COMPLETED FLAT GRID %>
  <% if completed_tasks.empty? %>
    <p class="no-tasks">No completed tasks yet — keep going! 💪</p>
  <% else %>
    <div class="completed-grid">
      <% completed_tasks.each do |task| %>
        <div class="task-card task-card--done" data-href="<%= task_path(task) %>" style="cursor:pointer;">
          <div class="card-top">
            <div class="card-tags">
              <% if task.pillar %>
                <span class="tag tag-pillar--<%= task.pillar.slug %>"><%= task.pillar.name %></span>
              <% end %>
            </div>
          </div>
          <h4 class="card-title"><%= task.name %></h4>
          <p class="card-desc"><%= task.description %></p>
        </div>
      <% end %>
    </div>
  <% end %>

<% else %>
<%# URGENT %>
<div class="kanban-col">
  <div class="col-header">
    <span class="col-dot urgent-dot"></span>
    <span class="col-title">Urgent</span>
    <span class="col-count"><%= urgent_count %></span>
    <span class="col-menu">⋯</span>
  </div>
  <% urgent_tasks.each do |task| %>
    <div class="task-card urgent-card" data-href="<%= task_path(task) %>" style="cursor:pointer;">
      <div class="card-top-row">
        <span class="urgent-badge">Urgent</span>
      </div>
      <h4 class="card-title"><%= task.name %></h4>
      <p class="card-desc"><%= task.description %></p>
      <div class="card-bottom-row">
        <span class="card-due urgent-due" style="display:inline-flex; align-items:center; gap:4px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <%= if task.due_date == Date.today
                "Today"
              elsif task.due_date == Date.today + 1.day
                "Tomorrow"
              elsif task.due_date == Date.today - 1.day
                "Yesterday"
              elsif task.due_date&.< Date.today
                "Overdue"
              else
                task.due_date&.strftime("%b %d")
              end %>
        </span>
      </div>
    </div>
  <% end %>
</div>

  <%# ACTIVE %>
  <div class="kanban-col">
    <div class="col-header">
      <span class="col-dot active-dot"></span>
      <span class="col-title">Active</span>
      <span class="col-count"><%= active_count %></span>
      <span class="col-menu">⋯</span>
    </div>
    <% active_tasks.each do |task| %>
      <div class="task-card" data-href="<%= task_path(task) %>" style="cursor:pointer;">
        <div class="card-top">
          <div class="card-tags">
            <span class="tag tag-medium">Medium</span>
            <% if task.pillar %>
              <span class="tag tag-pillar--<%= task.pillar.slug %>"><%= task.pillar.name %></span>
            <% end %>
          </div>
        </div>
        <h4 class="card-title"><%= task.name %></h4>
        <p class="card-desc"><%= task.description %></p>
        <div class="card-footer">
          <span class="card-progress-label">No progress yet</span>
          <span class="card-pct">0%</span>
        </div>
        <div class="card-track">
          <div class="card-fill" style="width: 0%;"></div>
        </div>
      </div>
    <% end %>
  </div>

  <%# UPCOMING %>
  <div class="kanban-col">
    <div class="col-header">
      <span class="col-dot upcoming-dot"></span>
      <span class="col-title">Upcoming</span>
      <span class="col-count"><%= upcoming_count %></span>
      <span class="col-menu">⋯</span>
    </div>
    <% upcoming_tasks.each do |task| %>
      <div class="task-card locked" data-href="<%= task_path(task) %>">
        <div class="card-top">
          <div class="card-tags">
            <span class="tag tag-low">Low</span>
            <% if task.pillar %>
              <span class="tag tag-pillar--<%= task.pillar.slug %>"><%= task.pillar.name %></span>
            <% end %>
          </div>
        </div>
        <h4 class="card-title"><%= task.name %></h4>
        <p class="card-desc"><%= task.description %></p>
        <div class="card-footer">
          <span class="card-progress-label">No progress yet</span>
          <span class="card-pct">0%</span>
        </div>
        <div class="card-track">
          <div class="card-fill" style="width: 0%;"></div>
        </div>
      </div>
    <% end %>
  </div>

<% end %>
