<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card shadow-sm p-4">
        <h1 class="h3 mb-4">Upload Document</h1>

        <%# Show validation errors if the form was submitted with missing fields %>
        <% if @chat.errors.any? %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% @chat.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: @chat, local: true, multipart: true do |f| %>
          <%# Links this scan to a specific admin task from the user's checklist %>
          <div class="mb-3">
            <%= f.label :checklist_item_id, "Linked Task", class: "form-label" %>
            <%= f.collection_select :checklist_item_id, ChecklistItem.all, :id, :title, { prompt: "Choose the relevant task..." }, { class: "form-select" } %>
          </div>

          <%# Upload area: two buttons trigger hidden file inputs. Stimulus controller shows instant preview before upload. %>
          <div class="mb-4" data-controller="uploadpreview">
            <%= f.label :document, "Document", class: "form-label" %>

            <div class="d-flex gap-2 mb-3">
              <%# Standard file upload — accepts images and PDFs %>
              <label class="btn btn-outline-primary d-inline-flex align-items-center gap-2" for="chat_document_upload">
                <i class="fa-solid fa-upload"></i>Upload File
              </label>
              <%# Camera button — hidden on desktop, shown on touch devices via .camera-only CSS %>
              <label class="btn btn-outline-primary camera-only d-inline-flex align-items-center gap-2" for="chat_document_camera">
                <i class="fa-solid fa-camera"></i>Take Photo
              </label>
            </div>

            <%= f.file_field :document, id: "chat_document_upload",
                class: "d-none", accept: "image/*,application/pdf",
                data: { action: "change->uploadpreview#show", uploadpreview_target: "input" } %>

            <%# Separate input with capture="environment" opens the rear camera on mobile %>
            <input type="file" id="chat_document_camera" name="chat[document]"
              accept="image/*" capture="environment" class="d-none"
              data-action="change->uploadpreview#show"
              data-uploadpreview-target="input" />

            <%# Image preview shown instantly for images; filename shown for PDFs %>
            <img data-uploadpreview-target="preview" class="img-fluid rounded mt-3 d-none" />
            <p data-uploadpreview-target="filename" class="mt-3 text-muted d-none">
              <i class="fa-solid fa-file-pdf text-danger me-1"></i>
            </p>
          </div>

          <div class="d-grid">
            <%= f.submit "Submit", class: "btn btn-primary" %>
          </div>
        <% end %>

        <%= link_to "Cancel", chats_path, class: "btn btn-link mt-2" %>
      </div>
    </div>
  </div>
</div>
