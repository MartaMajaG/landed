<div style="background:#F0F1F8; min-height:100vh; padding:48px 0;">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-md-7 col-lg-5">

        <div class="mb-4">
          <p style="font-size:11px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#7A9E1F; margin-bottom:6px;">Document Scanner</p>
          <h1 style="font-size:22px; font-weight:700; color:#1A1A2E; margin-bottom:4px;">Scan a document</h1>
          <p style="font-size:14px; color:#6B7280; margin-bottom:0;">Got a German letter you can't read? Plain-English summary in seconds.</p>
        </div>

        <div style="background:#fff; border:1px solid #E5E7EB; border-radius:12px; padding:28px;">

          <% if @chat.errors.any? %>
            <div class="alert alert-danger mb-4">
              <ul class="mb-0">
                <% @chat.errors.full_messages.each do |msg| %>
                  <li style="font-size:14px;"><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @chat, local: true, multipart: true do |f| %>

            <div class="mb-4" data-controller="uploadpreview">
              <label style="font-size:14px; font-weight:600; color:#1A1A2E; display:block; margin-bottom:8px;">Document</label>

              <div style="border:2px dashed #D1D5DB; border-radius:10px; padding:32px 20px; text-align:center; background:#F9FAFB;">
                <i class="fa-solid fa-cloud-arrow-up" style="font-size:28px; color:#9CA3AF; margin-bottom:12px; display:block;"></i>
                <p style="font-size:14px; color:#6B7280; margin-bottom:16px;">Upload a photo or file</p>
                <div class="d-flex justify-content-center gap-2">
                  <label style="background:#246DD5; color:#fff; border-radius:8px; padding:8px 18px; font-size:13px; font-weight:500; cursor:pointer; display:inline-flex; align-items:center; gap:6px;" for="chat_document_upload">
                    <i class="fa-solid fa-upload" style="font-size:12px;"></i> Upload file
                  </label>
                  <label class="camera-only" style="background:#fff; color:#246DD5; border:1.5px solid #246DD5; border-radius:8px; padding:8px 18px; font-size:13px; font-weight:500; cursor:pointer; display:inline-flex; align-items:center; gap:6px;" for="chat_document_camera">
                    <i class="fa-solid fa-camera" style="font-size:12px;"></i> Take photo
                  </label>
                </div>
              </div>

              <%= f.file_field :document, id: "chat_document_upload",
                    class: "d-none", accept: "image/*,application/pdf",
                    data: { action: "change->uploadpreview#show", uploadpreview_target: "input" } %>

              <input type="file" id="chat_document_camera" name="chat[document]"
                accept="image/*" capture="environment" class="d-none"
                data-action="change->uploadpreview#show"
                data-uploadpreview-target="input" />

              <img data-uploadpreview-target="preview" class="img-fluid rounded mt-3 d-none" style="max-height:200px;" />
              <p data-uploadpreview-target="filename" class="mt-3 d-none" style="font-size:13px; color:#6B7280;">
                <i class="fa-solid fa-file-pdf me-1" style="color:#E24B4A;"></i>
              </p>
            </div>

            <%= f.submit "Scan document", style:"width:100%; padding:11px; background:#246DD5; color:#fff; border:none; border-radius:8px; font-size:15px; font-weight:600; cursor:pointer;" %>

          <% end %>

          <%= link_to "Cancel", root_path, style:"display:block; text-align:center; margin-top:14px; font-size:14px; color:#6B7280; text-decoration:none;" %>

        </div>
      </div>
    </div>
  </di
</div>
