<div style="background:#F0F1F8; min-height:100vh; padding:48px 0;">
  <div class="container">

    <%# Full width header %>
    <div class="d-flex justify-content-between align-items-center mb-2">
      <p style="font-size:11px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#7A9E1F; margin-bottom:0;">AI Analysis</p>
      <%= link_to "← Back", new_chat_path, style:"font-size:13px; font-weight:500; color:#6B7280; text-decoration:none;" %>
    </div>
    <div class="mb-4">
      <h1 style="font-size:22px; font-weight:700; color:#1A1A2E; margin-bottom:6px;">
        <%= @chat.title || @chat.document.filename %>
      </h1>
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <small style="color:#6B7280;">Processed on <%= @chat.created_at.strftime("%b %d, %Y") %></small>
        <% if @chat.is_mandatory? || @chat.is_mandatory.nil? %>
          <span style="background:#E6F0FB; color:#185FA5; font-size:11px; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; padding:3px 8px; border-radius:20px;">
            MANDATORY
          </span>
        <% else %>
          <span style="background:#F3F4F6; color:#6B7280; font-size:11px; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; padding:3px 8px; border-radius:20px;">
            OPTIONAL
          </span>
        <% end %>

        <% if @chat.document_type.present? %>
          <%
            pillar_icon = case @chat.document_type
            when /Housing|Registration/i then "<i class='fa-solid fa-house'></i>".html_safe
            when /Finance|Banking|Bank/i then "<i class='fa-solid fa-building-columns'></i>".html_safe
            when /Health|Insurance/i then "<i class='fa-solid fa-notes-medical'></i>".html_safe
            when /Work|Employment/i then "<i class='fa-solid fa-briefcase'></i>".html_safe
            else "<i class='fa-solid fa-folder'></i>".html_safe
            end
          %>
          <span style="background:#E6F0FB; color:#185FA5; font-size:11px; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; padding:3px 8px; border-radius:20px;">
            <%= pillar_icon %> <%= @chat.document_type %>
          </span>
        <% end %>
        <% if @chat.urgency.present? %>
          <% badge_bg    = { "high" => "#FEE8E8", "medium" => "#FEF3CD", "low" => "#EBF5E0" }[@chat.urgency] %>
          <% badge_color = { "high" => "#A32D2D", "medium" => "#7C4A00", "low" => "#3B6D11" }[@chat.urgency] %>
          <span style="background:<%= badge_bg %>; color:<%= badge_color %>; font-size:11px; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; padding:3px 8px; border-radius:20px;">
            <%= @chat.urgency.capitalize %> urgency
          </span>
        <% end %>
      </div>
    </div>

    <%# Two columns — both start at same point %>
    <div class="row g-4 align-items-start">

      <%# Left: document preview %>
      <div class="col-12 col-md-5">
        <div style="background:#fff; border:1px solid #E5E7EB; border-radius:12px; padding:16px; display:flex; align-items:center; justify-content:center; min-height:320px;">
          <% if @chat.document.attached? && @chat.document.content_type.start_with?("image/") %>
            <%= image_tag url_for(@chat.document), style:"max-width:100%; max-height:480px; width:auto; height:auto; border-radius:8px; display:block;" %>
          <% elsif @chat.document.attached? %>
            <div style="text-align:center;">
              <i class="fa-solid fa-file-pdf" style="font-size:40px; color:#E24B4A;"></i>
              <p style="color:#6B7280; margin-top:12px; font-size:14px;"><%= @chat.document.filename %></p>
              <%= link_to "Download", url_for(@chat.document), class:"btn btn-sm btn-outline-secondary mt-2", target:"_blank" %>
            </div>
          <% end %>
        </div>
      </div>

      <%# Right: AI results %>
      <div class="col-12 col-md-7 d-flex flex-column gap-3">

        <% if @chat.deadline.present? || @chat.amount.present? %>
          <% both = @chat.deadline.present? && @chat.amount.present? %>
          <div class="row g-3">

            <% if @chat.deadline.present? %>
              <div class="<%= both ? 'col-6' : 'col-12' %>">
                <div style="background:#FEE8E8; border:1px solid #FCA5A5; border-radius:10px; padding:16px; height:100%;">
                  <div style="font-size:28px; line-height:1; margin-bottom:8px;">
                    <%= @chat.urgency == "high" ? "🚨" : "📅" %>
                  </div>
                  <p style="font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:#A32D2D; margin-bottom:6px;">
                    <%= @chat.urgency == "high" ? "Critical Deadline" : "Deadline" %>
                  </p>
                  <p style="font-size:20px; font-weight:700; color:#791F1F; margin-bottom:4px;">
                    <%= @chat.deadline.strftime("%b %d, %Y") %>
                  </p>
                  <% days_left = (@chat.deadline - Date.today).to_i %>
                  <small style="color:#A32D2D;">
                    <% if days_left < 0 %>Passed <%= days_left.abs %> days ago
                    <% else %><%= days_left %> days remaining
                    <% end %>
                  </small>
                </div>
              </div>
            <% end %>

            <% if @chat.amount.present? %>
              <div class="<%= both ? 'col-6' : 'col-12' %>">
                <% if @chat.amount <= 0 %>
                  <% amt_bg = "#EBF5E0"; amt_border = "#C0DD97"; amt_label_color = "#3B6D11"; amt_value_color = "#27500A" %>
                  <% amt_icon  = @chat.amount < 0 ? "💰" : "✅" %>
                  <% amt_label = @chat.amount < 0 ? "Potential Refund" : "No Payment Required" %>
                  <% amt_sub   = @chat.amount < 0 ? "You may receive this back" : "Nothing to pay here" %>
                <% else %>
                  <% amt_bg = "#FEE8E8"; amt_border = "#FCA5A5"; amt_label_color = "#A32D2D"; amt_value_color = "#791F1F" %>
                  <% amt_icon = "💸"; amt_label = "Amount Owed"; amt_sub = "See advice below" %>
                <% end %>
                <div style="background:<%= amt_bg %>; border:1px solid <%= amt_border %>; border-radius:10px; padding:16px; height:100%;">
                  <div style="font-size:28px; line-height:1; margin-bottom:8px;"><%= amt_icon %></div>
                  <p style="font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:<%= amt_label_color %>; margin-bottom:6px;">
                    <%= amt_label %>
                  </p>
                  <% if @chat.amount != 0 %>
                    <p style="font-size:20px; font-weight:700; color:<%= amt_value_color %>; margin-bottom:4px;">
                      €<%= number_with_precision(@chat.amount.abs, precision: 2) %>
                    </p>
                  <% end %>
                  <small style="color:<%= amt_label_color %>;"><%= amt_sub %></small>
                </div>
              </div>
            <% end %>

          </div>
        <% end %>

        <% if @chat.advice.present? %>
          <div style="background:#fff; border:1px solid #E5E7EB; border-radius:12px; padding:20px;">
            <h5 style="font-size:15px; font-weight:600; color:#1A1A2E; margin-bottom:14px;">
              <span style="font-size:18px; line-height:1; margin-right:6px;">⚡</span>What this means
            </h5>
            <ul style="font-size:14px; color:#4B5563; line-height:1.8; padding-left:18px; margin-bottom:0;">
              <% @chat.advice.split(/(?<=\.)\s+/).reject(&:blank?).each do |point| %>
                <li style="margin-bottom:6px;"><%= point.strip %></li>
              <% end %>
            </ul>
            <% if @chat.document.attached? %>
              <div style="margin-top: 14px;">
                <%= link_to url_for(@chat.document), target: "_blank", style: "display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 500; color: #4B5563; text-decoration: none; padding: 6px 12px; border: 1px solid #E5E7EB; border-radius: 6px; background: #F9FAFB;" do %>
                  <i class="fa-solid fa-file-pdf" style="color: #E24B4A;"></i> View full document
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if @chat.description.present? %>
          <div style="background:#fff; border:1px solid #E5E7EB; border-radius:12px; padding:20px;">
            <h5 style="font-size:15px; font-weight:600; color:#1A1A2E; margin-bottom:14px;">
              <span style="font-size:18px; line-height:1; margin-right:6px;">📋</span>Next steps
            </h5>
            <ul style="font-size:14px; color:#4B5563; line-height:1.8; padding-left:18px; margin-bottom:0;">
              <% @chat.description.split("\n").reject(&:blank?).each do |step| %>
                <li style="margin-bottom:6px;"><%= step.gsub(/^[-•\d.]\s*/, "").strip %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

      </div>
    </div>

    <%# AI Chat Panel — full width below the two-column results %>
    <% if @chat.advice.present? %>
      <div style="margin-top: 32px;">
        <div style="background:#fff; border:1px solid #E5E7EB; border-radius:12px; overflow:hidden;">

          <%# Panel header %>
          <div style="padding: 14px 20px; border-bottom: 1px solid #E5E7EB; display:flex; align-items:center; gap:8px;">
            <span style="font-size:16px;">🤖</span>
            <p style="font-size:13px; font-weight:700; color:#1A1A2E; margin:0;">Ask AI about this document</p>
          </div>

          <%# Message history — only shown if messages exist %>
          <% if @chat.messages.any? %>
            <div style="padding: 16px 20px; display:flex; flex-direction:column; gap:12px; max-height:320px; overflow-y:auto;">
              <% @chat.messages.order(:created_at).each do |message| %>
                <% if message.role == "user" %>
                  <%# User message — right aligned, blue bubble %>
                  <div style="display:flex; justify-content:flex-end;">
                    <div style="background:#185FA5; color:#fff; font-size:14px; line-height:1.6; padding:10px 14px; border-radius:16px 16px 4px 16px; max-width:75%;">
                      <%= message.content %>
                    </div>
                  </div>
                <% else %>
                  <%# Assistant message — left aligned, grey bubble %>
                  <div style="display:flex; justify-content:flex-start; gap:8px; align-items:flex-start;">
                    <div style="width:28px; height:28px; background:#F0F1F8; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:13px;">🤖</div>
                    <div style="background:#F3F4F6; color:#1A1A2E; font-size:14px; line-height:1.6; padding:10px 14px; border-radius:16px 16px 16px 4px; max-width:75%;">
                      <%= message.content %>
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% end %>

          <%# Input form %>
          <div style="padding: 12px 16px; border-top: 1px solid #E5E7EB; background:#FAFAFA;">

            <%# Quick-question chips %>
            <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:10px;">
              <% ["What is the deadline?", "What do I need to bring?", "Is there a penalty if I miss it?"].each do |chip| %>
                <button
                  type="button"
                  onclick="document.getElementById('chat-input-<%= @chat.id %>').value = '<%= chip %>'"
                  style="font-size:12px; color:#185FA5; background:#E6F0FB; border:none; border-radius:20px; padding:4px 12px; cursor:pointer; font-weight:500;">
                  <%= chip %>
                </button>
              <% end %>
            </div>

            <%# Text input and send button %>
            <%= form_with url: chat_messages_path(@chat), method: :post, style: "display:flex; gap:8px; align-items:center;" do |f| %>
              <%= f.text_field :message,
                    name: "message[content]",
                    id: "chat-input-#{@chat.id}",
                    placeholder: "Ask AI a question about this document...",
                    autocomplete: "off",
                    required: true,
                    style: "flex:1; font-size:14px; padding:10px 14px; border:1px solid #E5E7EB; border-radius:24px; outline:none; background:#fff; color:#1A1A2E;" %>
              <%= f.submit "→",
                    style: "width:38px; height:38px; background:#185FA5; color:#fff; border:none; border-radius:50%; font-size:18px; cursor:pointer; flex-shrink:0; display:flex; align-items:center; justify-content:center;" %>
            <% end %>
          </div>

        </div>
      </div>
    <% end %>

  </div>
</div>
