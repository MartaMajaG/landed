<% content_for :meta_title, "Landed | #{@chat.title || @chat.document.filename}" %>

<%# Subscribe to this chat's ActionCable channel so background job broadcasts reach the browser %>
<%= turbo_stream_from @chat %>

<style>
  .chat-spinner-inline {
    width: 24px;
    height: 24px;
    border: 3px solid #E5E7EB;
    border-top-color: #246DD5;
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
    display: inline-block;
    vertical-align: middle;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .chat-input-row {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #F8F9FA;
    border: 1.5px solid #E5E7EB;
    border-radius: 16px;
    padding: 10px 14px;
    transition: border-color 0.15s;
  }
  .chat-input-row:focus-within {
    border-color: #246DD5;
    background: #fff;
  }
  .chat-input-field {
    flex: 1;
    min-width: 0;
    font-size: 14px;
    border: none;
    outline: none;
    background: transparent;
    color: #1A1A2E;
    padding: 0;
  }
  .chat-input-field::placeholder { color: #9CA3AF; }
  .chat-send-btn {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    background: #246DD5;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .chat-send-btn:hover { background: #1a56b0; }
  .chat-send-btn:disabled { background: #9CA3AF; cursor: not-allowed; }
  .chat-chip {
    font-size: 12px;
    color: #374151;
    background: #F3F4F6;
    border: 1px solid #E5E7EB;
    border-radius: 20px;
    padding: 5px 14px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.12s;
  }
  .chat-chip:hover {
    background: #E6F0FB;
    border-color: #246DD5;
    color: #246DD5;
  }
  .chat-panel-header {
    padding: 14px 20px;
    border-bottom: 1px solid #F3F4F6;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    user-select: none;
  }
  .chat-panel-header:hover { background: #F9FAFB; }
</style>

<div style="background:#F0F1F8; min-height:100vh; padding:24px 0;">
  <div class="container">

    <%# ── BREADCRUMB ── %>
    <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:#6B7280; margin-bottom:3rem;">
  <%= link_to "Documents", chats_path, style:"color:#6B7280; text-decoration:none; font-weight:400;" %>
  <span style="color:#9CA3AF;">/</span>
  <span style="color:#1A1A2E; font-weight:500;"><%= @chat.title || @chat.document.filename %></span>
</div>

    <%# ── HEADER ── %>
    <div style="margin-bottom:2rem;">
      <p style="font-size:11px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#7A9E1F; margin-bottom:4px;">Document Analysis</p>
      <h1 style="font-size:22px; font-weight:700; color:#1A1A2E; margin:0 0 10px; word-break: normal;">
        <%= @chat.title || @chat.document.filename %>
      </h1>
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <small style="color:#6B7280;">Processed on <%= @chat.created_at.strftime("%b %d, %Y") %></small>
        <% if @chat.is_mandatory? || @chat.is_mandatory.nil? %>
          <span style="background:#E6F0FB; color:#185FA5; font-size:11px; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; padding:3px 8px; border-radius:20px;">Mandatory</span>
        <% else %>
          <span style="background:#F3F4F6; color:#6B7280; font-size:11px; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; padding:3px 8px; border-radius:20px;">Optional</span>
        <% end %>
        <% if @chat.document_type.present? %>
          <span style="background:#E6F0FB; color:#185FA5; font-size:11px; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; padding:3px 8px; border-radius:20px;">
            <%= @chat.document_type %>
          </span>
        <% end %>
      </div>
    </div>

    <%# ── TWO COLUMNS ── %>
    <div class="row g-4 align-items-start">

      <%# ── LEFT: document preview ── %>
      <div class="col-12 col-md-5">
        <div style="background:#fff; border-radius:12px; padding:16px; display:flex; align-items:flex-start; justify-content:center; overflow:hidden; max-height:500px;">
          <% if @chat.document.attached? && @chat.document.content_type.start_with?("image/") %>
              <%= image_tag url_for(@chat.document), style:"max-width:100%; max-height:480px; width:auto; height:auto; border-radius:8px; display:block;" %>
          <% elsif @chat.document.attached? %>
            <div style="text-align:center;">
              <i class="fa-solid fa-file-pdf" style="font-size:40px; color:#E24B4A;"></i>
              <p style="color:#6B7280; margin-top:12px; font-size:14px;"><%= @chat.document.filename %></p>
              <%= link_to "Download", url_for(@chat.document), class:"btn btn-sm btn-outline-secondary mt-2", target:"_blank" %>
            </div>
          <% end %>
        </div>
      </div>

      <%# ── RIGHT: AI results ── %>
      <div class="col-12 col-md-7 d-flex flex-column gap-2">

        <% if @chat.deadline.present? || @chat.amount.present? %>
          <div class="row g-3">

            <%# ── DEADLINE CARD ── %>
<div class="col-6">
  <% if @chat.deadline.present? %>
    <% days_left = (@chat.deadline - Date.today).to_i %>
    <div style="background:#fff; border-radius:12px; padding:20px; height:100%;">
      <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
        <i class="fa-solid fa-calendar-xmark" style="font-size:16px; color:<%= @chat.urgency == 'high' ? '#A32D2D' : '#246DD5' %>;"></i>
        <p style="font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:<%= @chat.urgency == 'high' ? '#A32D2D' : '#374151' %>; margin:0;">
          <%= @chat.urgency == "high" ? "Critical Deadline" : "Deadline" %>
        </p>
      </div>
      <p style="font-size:22px; font-weight:700; color:#1A1A2E; margin:0 0 4px;">
        <%= @chat.deadline.strftime("%b %d, %Y") %>
      </p>
      <small style="color:<%= days_left < 0 ? '#A32D2D' : '#6B7280' %>;">
        <% if days_left < 0 %>Passed <%= days_left.abs %> <%= 'day'.pluralize(days_left.abs) %> ago
        <% elsif days_left == 0 %>Due today
        <% else %><%= days_left %> days remaining
        <% end %>
      </small>
    </div>
  <% else %>
    <div style="background:#fff; border-radius:12px; padding:20px; height:100%;">
      <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
        <i class="fa-solid fa-calendar-check" style="font-size:16px; color:#9CA3AF;"></i>
        <p style="font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:#9CA3AF; margin:0;">Deadline</p>
      </div>
      <p style="font-size:22px; font-weight:700; color:#6B7280; margin:0;">No deadline</p>
    </div>
  <% end %>
</div>

            <%# ── AMOUNT CARD ── %>
            <% if @chat.amount.present? %>
              <div class="col-6">
                <% if @chat.amount < 0 %>
                  <% amt_icon = "fa-money-bill-transfer"; amt_color = "#3B6D11"; amt_label = "Potential Refund"; amt_sub = "You may receive this back" %>
                <% elsif @chat.amount == 0 %>
                  <% amt_icon = "fa-circle-check"; amt_color = "#3B6D11"; amt_label = "No Payment Required"; amt_sub = "Nothing to pay here" %>
                <% else %>
                  <% amt_icon = "fa-circle-exclamation"; amt_color = "#A32D2D"; amt_label = "Amount Owed"; amt_sub = "" %>
                <% end %>
                <div style="background:#fff; border-radius:12px; padding:20px; height:100%;">
  <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
    <i class="fa-solid <%= amt_icon %>" style="font-size:16px; color:<%= amt_color %>;"></i>
                    <p style="font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:<%= amt_color %>; margin:0;">
                      <%= amt_label %>
                    </p>
                  </div>
                  <% if @chat.amount != 0 %>
                    <p style="font-size:22px; font-weight:700; color:#1A1A2E; margin:0 0 4px;">
                      €<%= number_with_precision(@chat.amount.abs, precision: 2) %>
                    </p>
                  <% end %>
                  <small style="color:#6B7280;"><%= amt_sub %></small>
                </div>
              </div>
            <% end %>

          </div>
        <% end %>

        <%# ── WHAT THIS MEANS ── %>
        <% if @chat.advice.present? %>
          <div style="background:#fff; border-radius:12px; padding:24px;">
            <h5 style="font-size:15px; font-weight:600; color:#1A1A2E; margin-bottom:14px; display:flex; align-items:center; gap:8px;">
              <i class="fa-solid fa-bolt" style="color:#F59E0B; font-size:14px;"></i> What this means
            </h5>
            <ul style="font-size:14px; color:#4B5563; line-height:1.8; padding-left:12px; margin-bottom:0; max-width:680px;">
              <% @chat.advice.split(/(?<=[.!?])\s+/).reject(&:blank?).select { |p| p.length > 10 }.each do |point| %>
                <li style="margin-bottom:6px;"><%= point.strip %></li>
              <% end %>
            </ul>
            <% if @chat.document.attached? %>
              <div style="margin-top:16px;">
                <%= link_to url_for(@chat.document), target: "_blank", style: "display:inline-flex; align-items:center; gap:6px; font-size:13px; font-weight:500; color:#4B5563; text-decoration:none; padding:6px 12px; border:1px solid #E5E7EB; border-radius:6px; background:#F9FAFB;" do %>
                  <i class="fa-solid fa-file-pdf" style="color:#E24B4A;"></i> View full document
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# ── NEXT STEPS ── %>
        <% if @chat.description.present? %>
          <div style="background:#fff; border-radius:12px; padding:24px;">
            <h5 style="font-size:15px; font-weight:600; color:#1A1A2E; margin-bottom:14px; display:flex; align-items:center; gap:8px;">
              <i class="fa-solid fa-list-check" style="color:#246DD5; font-size:14px;"></i> Next steps
            </h5>
            <ul style="font-size:14px; color:#4B5563; line-height:1.8; padding-left:18px; margin-bottom:0;">
              <% @chat.description.split("\n").reject(&:blank?).each do |step| %>
                <li style="margin-bottom:6px;"><%= step.gsub(/^[-•\d.]\s*/, "").strip %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

      </div>
    </div>

    <%# ── AI CHAT PANEL ── %>
    <% if @chat.advice.present? %>
      <div class="row mt-4">
        <div class="col-12">
          <div style="background:#fff; border:1px solid #E5E7EB; border-radius:16px; overflow:hidden;">

            <%# ── COLLAPSIBLE HEADER ── %>
            <div class="chat-panel-header"
                 onclick="
                   const body = document.getElementById('chat-body-<%= @chat.id %>');
                   const arrow = document.getElementById('chat-arrow-<%= @chat.id %>');
                   if (body.style.display === 'none') {
                     body.style.display = 'block';
                     arrow.textContent = '▲';
                   } else {
                     body.style.display = 'none';
                     arrow.textContent = '▼';
                   }">
              <div style="display:flex; align-items:center; gap:8px;">
                <div style="width:28px; height:28px; background:#E6F0FB; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:13px;">✦</div>
                <p style="font-size:13px; font-weight:600; color:#1A1A2E; margin:0;">Ask about this document</p>
                <% if @chat.messages.any? %>
                  <span style="font-size:11px; color:#6B7280; font-weight:400;"><%= @chat.messages.count %> messages</span>
                <% end %>
              </div>
              <span id="chat-arrow-<%= @chat.id %>" style="font-size:11px; color:#6B7280;">▼</span>
            </div>

            <%# ── COLLAPSIBLE BODY ── %>
            <div id="chat-body-<%= @chat.id %>" style="display:none;">

              <%# ── MESSAGE HISTORY ── %>
              <% if @chat.messages.any? %>
  <div id="chat-messages-<%= @chat.id %>"
      style="padding:16px 20px; display:flex; flex-direction:column; gap:8px; max-height:400px; overflow-y:auto;">
    <% @chat.messages.order(:created_at).each do |message| %>
                  <% if message.role == "user" %>
                    <div style="display:flex; justify-content:flex-end;">
                      <div style="background:#246DD5; color:#fff; font-size:14px; line-height:1.6; padding:10px 14px; border-radius:16px 16px 4px 16px; max-width:75%;">
                        <%= message.content %>
                      </div>
                    </div>
                  <% else %>
                    <div style="display:flex; justify-content:flex-start; gap:8px; align-items:flex-start;">
                      <div style="width:28px; height:28px; background:#E6F0FB; border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:13px;">✦</div>
                      <div style="background:#F3F4F6; color:#1A1A2E; font-size:14px; line-height:1.6; padding:10px 14px; border-radius:16px 16px 16px 4px; max-width:75%;">
                        <%= message.content %>
                      </div>
                    </div>
                  <% end %>
                <% end %>
  </div>
<% else %>
  <div id="chat-messages-<%= @chat.id %>" style="padding:16px 20px; display:flex; flex-direction:column; gap:8px; max-height:400px; overflow-y:auto;"></div>
<% end %>

              <%# ── INPUT AREA ── %>
              <div style="padding:14px 16px; border-top:<%= @chat.messages.any? ? '1px solid #F3F4F6' : 'none' %>;">
                <div id="chat-input-wrapper-<%= @chat.id %>">
                  <%= form_with url: chat_messages_path(@chat), method: :post,
                        data: { controller: "chat-form", action: "submit->chat-form#disableSubmit" } do |f| %>
                    <div class="chat-input-row">
                      <%= f.text_field :message,
                            name: "message[content]",
                            id: "chat-input-#{@chat.id}",
                            placeholder: "Ask a question about this document...",
                            autocomplete: "off",
                            required: true,
                            class: "chat-input-field" %>
                      <%= f.submit "→", class: "chat-send-btn" %>
                    </div>
                  <% end %>
                </div>

                <%# ── QUICK CHIPS ── %>
                <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:10px;">
                  <% ["What is the deadline?", "What do I need to bring?", "Is there a penalty if I miss it?"].each do |chip| %>
                    <button
                      type="button"
                      class="chat-chip"
                      onclick="
                        const body = document.getElementById('chat-body-<%= @chat.id %>');
                        const arrow = document.getElementById('chat-arrow-<%= @chat.id %>');
                        body.style.display = 'block';
                        arrow.textContent = '▲';
                        document.getElementById('chat-input-<%= @chat.id %>').value = '<%= chip %>';
                      ">
                      <%= chip %>
                    </button>
                  <% end %>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    <% end %>

  </div>
</div>
