<div class="container py-5">
  <div class="card shadow-sm p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0">Document Analysis</h1>
      <span class="badge bg-secondary">Processing...</span>
    </div>

    <div class="p-3 bg-light rounded mb-4">
      <div class="d-flex align-items-center">
        <% icon, color = case @chat.document.content_type
           when /image/ then ["fa-file-image", "text-primary"]
           when /pdf/   then ["fa-file-pdf",   "text-danger"]
           when /word/  then ["fa-file-word",  "text-primary"]
           else              ["fa-file",        "text-secondary"]
           end %>
        <i class="fa-solid <%= icon %> <%= color %> h2 mb-0 me-3"></i>
        <div>
          <h5 class="mb-0"><%= @chat.document.filename %></h5>
          <small class="text-muted"><%= number_to_human_size(@chat.document.byte_size) %></small>
        </div>
      </div>

        <% if @chat.document.content_type.start_with?("image/") %>
          <%= image_tag url_for(@chat.document), class: "img-fluid rounded", style: "max-height: 400px;" %>
        <% else %>
          <%= link_to "Download content", url_for(@chat.document), class: "btn btn-outline-secondary btn-sm", target: "_blank" %>
        <% end %>
    </div>

    <div class="alert alert-info">
      <h4 class="h6">AI Processing</h4>
      <p class="mb-0">We are currently scanning this document for the task: <strong><%= @chat.checklist_item.title %></strong>. Results will be available soon.</p>
    </div>

    <div class="mt-4">
      <%= link_to "Back to all scans", chats_path, class: "btn btn-outline-primary" %>
    </div>
  </div>
</div>
