<% content_for :meta_title, "Landed | Documents" %>

<div style="background:#F0F1F8; min-height:100vh; padding:48px 0;">
  <div class="container">

<%# ── HEADER ── %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 style="font-size:28px; font-weight:700; color:#1A1A2E; margin:0 0 4px;">My Documents</h1>
    <% if @chats.any? %>
      <p style="font-size:14px; color:#6B7280; margin:0;"><%= @chats.size %> documents scanned</p>
    <% end %>
  </div>
  <% if @chats.any? %>
    <%= link_to "＋ Scan new document", new_chat_path,
        style: "background:#246DD5; color:#fff; font-size:14px; font-weight:500; padding:10px 20px; border-radius:8px; text-decoration:none;" %>
  <% end %>
</div>

<% if @chats.empty? %>
  <div style="text-align:center; padding:80px 0;">
    <p style="font-size:48px; margin-bottom:16px;">📄</p>
    <h2 style="font-size:20px; font-weight:600; color:#1A1A2E; margin-bottom:8px;">No documents yet</h2>
    <p style="font-size:14px; color:#6B7280; margin-bottom:24px;">Scan your first German document to get started.</p>
    <%= link_to "Scan your first document", new_chat_path,
        style: "background:#246DD5; color:#fff; font-size:14px; font-weight:500; padding:10px 20px; border-radius:8px; text-decoration:none;" %>
  </div>

<% else %>
  <div style="background:#fff; border:1px solid #E5E7EB; border-radius:12px; overflow:hidden;">

        <%# ── TABLE HEADER ── %>
        <div style="display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:16px; padding:12px 20px; background:#F9FAFB; border-bottom:1px solid #E5E7EB;">
          <span style="font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:#6B7280;">Document</span>
          <span style="font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:#6B7280;">Type</span>
          <span style="font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:#6B7280;">Deadline</span>
          <span style="font-size:11px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; color:#6B7280;">Scanned</span>
        </div>

        <%# ── ROWS ── %>
        <% @chats.each do |chat| %>
          <%= link_to chat_path(chat),
              style: "display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:16px; padding:16px 20px; border-bottom:1px solid #F3F4F6; align-items:center; text-decoration:none; color:inherit; cursor:pointer; transition:background 0.15s;",
              onmouseover: "this.style.background='#F9FAFB'",
              onmouseout: "this.style.background=''" do %>

            <%# ── DOCUMENT TITLE + URGENCY ── %>
            <div style="display:flex; align-items:center; gap:12px;">
              <div style="width:36px; height:36px; background:#E6F0FB; border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                <span style="font-size:16px;">📄</span>
              </div>
              <div>
                <p style="font-size:14px; font-weight:600; color:#1A1A2E; margin:0 0 2px;">
                  <%= chat.title || chat.document.filename %>
                </p>
                <% if chat.urgency.present? %>
                  <% badge_bg    = { "high" => "#FEE8E8", "medium" => "#FEF3CD", "low" => "#EBF5E0" }[chat.urgency] %>
                  <% badge_color = { "high" => "#A32D2D", "medium" => "#7C4A00", "low" => "#3B6D11" }[chat.urgency] %>
                  <span style="font-size:10px; font-weight:700; letter-spacing:0.04em; text-transform:uppercase; background:<%= badge_bg %>; color:<%= badge_color %>; padding:2px 6px; border-radius:20px;">
                    <%= chat.urgency %>
                  </span>
                <% end %>
              </div>
            </div>

            <%# ── DOCUMENT TYPE ── %>
            <div>
              <% if chat.document_type.present? %>
                <span style="font-size:12px; font-weight:600; background:#E6F0FB; color:#185FA5; padding:3px 8px; border-radius:20px;">
                  <%= chat.document_type %>
                </span>
              <% else %>
                <span style="font-size:12px; color:#9CA3AF;">—</span>
              <% end %>
            </div>

            <%# ── DEADLINE ── %>
            <div>
              <% if chat.deadline.present? %>
                <% days_left = (chat.deadline - Date.today).to_i %>
                <p style="font-size:13px; font-weight:500; color:<%= days_left < 7 ? '#A32D2D' : '#374151' %>; margin:0;">
                  <%= chat.deadline.strftime("%b %d, %Y") %>
                </p>
                <p style="font-size:11px; color:#9CA3AF; margin:0;">
                  <% if days_left < 0 %>Overdue
                  <% elsif days_left == 0 %>Today
                  <% else %><%= days_left %> days left
                  <% end %>
                </p>
              <% else %>
                <span style="font-size:12px; color:#9CA3AF;">—</span>
              <% end %>
            </div>

            <%# ── DATE SCANNED + DELETE ── %>
<div style="display:flex; justify-content:space-between; align-items:center;">
  <p style="font-size:12px; color:#6B7280; margin:0;"><%= chat.created_at.strftime("%b %d, %Y") %></p>
  <%= button_to "Delete", chat_path(chat),
      method: :delete,
      form: {
        data: { turbo_confirm: "Are you sure you want to delete this document?" },
        onclick: "event.stopPropagation();"
      },
      style: "background:none; border:1px solid #E5E7EB; border-radius:6px; font-size:12px; font-weight:500; color:#6B7280; cursor:pointer; padding:4px 10px;",
      onmouseover: "this.style.borderColor='#A32D2D'; this.style.color='#A32D2D'",
      onmouseout: "this.style.borderColor='#E5E7EB'; this.style.color='#6B7280'" %>
</div>

          <% end %>
        <% end %>

      </div>
    <% end %>

  </div>
</div>
