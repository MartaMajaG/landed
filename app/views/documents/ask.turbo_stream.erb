<%= turbo_stream.update "ai_chat_response" do %>
  <div class="p-3 rounded shadow-sm bg-white border" style="border-left: 4px solid #ffc107 !important;">
    <div class="d-flex align-items-center mb-2">
      <i class="bi bi-robot text-warning me-2 fs-5"></i>
      <div>
        <strong class="text-dark small d-block">AI Response</strong>
        <span class="text-muted" style="font-size: 0.75rem;">Q: "<%= @question %>"</span>
      </div>
    </div>
    <p class="mb-0 text-dark small"><%= @answer %></p>
  </div>
<% end %>

<%= turbo_stream.replace "ai_ask_form" do %>
  <%= form_with url: ask_document_path(@document), method: :post, class: "ai-ask-bar", id: "ai_ask_form" do |f| %>
    <i class="bi bi-stars text-warning px-2"></i>
    <%= f.text_field :question, placeholder: "Ask another question...", class: "border-0 shadow-none bg-transparent flex-grow-1 outline-none", style: "outline: none;", autofocus: true %>
    <button type="submit" class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; flex-shrink: 0;" data-disable-with="<i class='bi bi-hourglass-split'></i>">
      <i class="bi bi-arrow-right"></i>
    </button>
  <% end %>
<% end %>
