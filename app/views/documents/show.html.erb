<div class="container-fluid px-5 py-5 bg-light min-vh-100">
  <div class="row g-4">

    <%# LEFT: Document Preview %>
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 20px; height: calc(100vh - 120px);">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div class="btn-group border rounded-3 shadow-sm bg-white">
            <button class="btn btn-sm py-2 px-3"><i class="bi bi-search"></i></button>
            <button class="btn btn-sm py-2 px-3 border-start"><i class="bi bi-plus-lg"></i></button>
            <button class="btn btn-sm py-2 px-3 border-start"><i class="bi bi-fullscreen"></i></button>
          </div>

        </div>

        <div class="rounded-3 d-flex align-items-center justify-content-center overflow-auto h-100 p-3"
             style="background: #f8f9fa; border: 1.5px dashed #dee2e6;">
          <% if @document.file.attached? %>
            <%= image_tag @document.file, class: "img-fluid shadow-sm rounded-2 border" %>
          <% else %>
            <div class="text-center text-muted">
              <i class="bi bi-file-earmark-text" style="font-size: 3rem; opacity: 0.3;"></i>
              <p class="small mt-2 mb-0">No file attached</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# RIGHT: Analysis %>
    <div class="col-lg-7 pt-2"">
      <div style="max-height: calc(100vh - 120px); overflow-y: auto;">
        <%= render "analysis_result", document: @document %>
      </div>
    </div>

  </div>
</div>