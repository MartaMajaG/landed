<% onboarding_page = controller_name == "onboardings" %>

<nav class="navbar navbar-expand-sm navbar-light navbar-lewagon">
  <div class="container">
    <%= link_to "Landed", root_path, class: "navbar-brand" %>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav me-auto ps-5">
        <% if user_signed_in? %>

          <li class="nav-item">
            <%= link_to "Dashboard", dashboard_path, class: "nav-link #{'active' if current_page?(dashboard_path)}" %>
          </li>
          <li class="nav-item">
            <%= link_to "Documents", chats_path, class: "nav-link #{'active' if current_page?(chats_path)}" %>
          </li>
          <%# <li class="nav-item">
            <%= link_to "Community", "#", class: "nav-link #{'active' if current_page?('#')}" %>
          </li>
        <% end %>
      </ul>

      <ul class="navbar-nav ms-auto">
        <% if onboarding_page %>
          <li class="nav-item">
            <%= link_to "Help", "#", class: "nav-link" %>
          </li>
        <% elsif user_signed_in? %>
          <li class="nav-item me-3 d-flex align-items-center">
            <%= image_tag "icon.svg", style: "height: 26px; width: auto;" %>
          </li>
          <li class="nav-item dropdown">
            <%= image_tag "profile.svg", class: "avatar dropdown-toggle", style: "cursor: pointer;", id: "navbarDropdown", data: { bs_toggle: "dropdown" }, aria: { haspopup: true, expanded: false } %>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
              <%= link_to "My profile", profile_path, class: "dropdown-item" %>
              <%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item" %>
            </div>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Sign in", new_user_session_path, class: "nav-link" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>
