<% onboarding_page = controller_name == "onboardings" %>

<% if onboarding_page %>
  <nav class="navbar navbar-expand-sm navbar-light navbar-lewagon">
    <div class="container">
      <%= link_to "Landed", root_path, class: "navbar-brand" %>
      <ul class="navbar-nav ms-auto align-items-center gap-1">
        <li class="nav-item">
          <%= link_to "Help", "#", class: "nav-link" %>
        </li>
      </ul>
    </div>
  </nav>
<% elsif user_signed_in? %>
  <aside class="landed-sidebar">
    <div class="sidebar-logo">
      <%= link_to root_path, class: "sidebar-brand-link" do %>
        <div class="sidebar-logomark">L</div>
      <% end %>
    </div>

    <nav class="sidebar-nav">
      <%= link_to dashboard_path, class: "sidebar-link #{'active' if current_page?(dashboard_path)}", data: { label: "Dashboard" } do %>
        <i class="bi bi-house"></i>
      <% end %>
      <%= link_to chats_path, class: "sidebar-link #{'active' if current_page?(chats_path)}", data: { label: "Documents" } do %>
        <i class="bi bi-file-text"></i>
      <% end %>
    </nav>

    <div class="sidebar-bottom">
      <button class="sidebar-link" aria-label="Notifications">
        <i class="bi bi-bell"></i>
      </button>

      <div class="dropdown">
        <button class="sidebar-link" id="sidebarDropdown" data-bs-toggle="dropdown" aria-expanded="false">
          <i class="bi bi-person-circle"></i>
        </button>
        <ul class="dropdown-menu sidebar-dropdown" aria-labelledby="sidebarDropdown">
          <li><%= link_to "My profile", profile_path, class: "dropdown-item" %></li>
          <li><%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item" %></li>
        </ul>
      </div>
    </div>
  </aside>
<% else %>
  <nav class="navbar navbar-expand-sm navbar-light navbar-lewagon">
    <div class="container">
      <%= link_to "Landed", root_path, class: "navbar-brand" %>
      <ul class="navbar-nav ms-auto align-items-center gap-1">
        <li class="nav-item">
          <%= link_to "Sign in", new_user_session_path, class: "nav-link" %>
        </li>
      </ul>
    </div>
  </nav>
<% end %>
