<% content_for :meta_title, "Landed | Profile" %>

<div class="onboarding-page profile-page">
  <div class="onboarding-shell">
    <div class="profile-heading">
      <h1>Your profile</h1>
      <p>Your relocation details in one place.</p>
    </div>

    <div class="onboarding-panel profile-card">
      <p><strong>Name:</strong> <%= [@profile.first_name, @profile.last_name].compact_blank.join(" ").presence || "Not added yet" %></p>
      <p><strong>City:</strong> <%= @profile.city&.name || "Not selected yet" %></p>
      <p><strong>Country:</strong> <%= @profile.city&.country || "Germany" %></p>
      <p><strong>Arrival date:</strong> <%= @profile.arrival_date || "Skipped for now" %></p>
      <p><strong>Visa status:</strong> <%= @profile.visa_status&.humanize || "Not selected yet" %></p>
      <p><strong>Home:</strong> <%= @profile.has_home.nil? ? "Not selected yet" : (@profile.has_home ? "Yes" : "No") %></p>
    </div>

    <div class="onboarding-actions">
      <%= link_to "Edit Profile", edit_profile_path, class: "onboarding-button profile-button" %>
    </div>
  </div>
</div>
