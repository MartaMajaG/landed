<% content_for :meta_title, "Landed | Create account" %>

<div class="auth-page">
  <div class="auth-shell">
    <div class="auth-heading">
      <h1>Create account</h1>
      <p>Start your relocation journey</p>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <div class="auth-card">
        <% if resource.errors.any? %>
          <div class="auth-alert" role="alert">
            <%= resource.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <div class="auth-field">
          <%= f.label :email, "Email", class: "auth-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-input" %>
        </div>

        <div class="auth-field">
          <%= f.label :password, "Password", class: "auth-label" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "auth-input" %>
          <% if @minimum_password_length %>
            <p class="auth-hint"><%= @minimum_password_length %> characters minimum</p>
          <% end %>
        </div>

        <div class="auth-field">
          <%= f.label :password_confirmation, "Confirm password", class: "auth-label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "auth-input" %>
        </div>
      </div>

      <div class="auth-actions">
        <%= f.submit "Create account", class: "auth-button" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
