<%# 1. Append the user's message bubble %>
<%= turbo_stream.append "chat-messages-#{@chat.id}" do %>
  <div style="display:flex; justify-content:flex-end;">
    <div style="background:#246DD5; color:#fff; font-size:14px; line-height:1.6; padding:10px 14px; border-radius:16px 16px 4px 16px; max-width:75%;">
      <%= @user_message.content %>
    </div>
  </div>
<% end %>

<%# 2. Append loading bubble %>
<%= turbo_stream.append "chat-messages-#{@chat.id}" do %>
  <div id="ai-loading-<%= @user_message.id %>"
       style="display:flex; justify-content:flex-start; gap:8px; align-items:flex-start;">
    <div style="width:28px; height:28px; background:#E6F0FB; border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:13px;">✦</div>
    <div style="background:#F3F4F6; padding:12px 14px; border-radius:16px 16px 16px 4px;">
      <div class="chat-spinner-inline"></div>
    </div>
  </div>
<% end %>

<%# 3. Clear and reset the input form %>
<%= turbo_stream.replace "chat-input-wrapper-#{@chat.id}" do %>
  <div id="chat-input-wrapper-<%= @chat.id %>">
    <%= form_with url: chat_messages_path(@chat), method: :post,
          data: { controller: "chat-form", action: "submit->chat-form#disableSubmit" } do |f| %>
      <div class="chat-input-row">
        <%= f.text_field :message,
              name: "message[content]",
              id: "chat-input-#{@chat.id}",
              placeholder: "Ask a question about this document...",
              autocomplete: "off",
              required: true,
              class: "chat-input-field" %>
        <%= f.submit "→", class: "chat-send-btn" %>
      </div>
    <% end %>
  </div>
<% end %>
