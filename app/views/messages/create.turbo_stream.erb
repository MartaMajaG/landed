<%# 1. Append the user's message bubble to the message history %>
<%= turbo_stream.append "chat-messages-#{@chat.id}" do %>
  <div style="display:flex; justify-content:flex-end; margin-bottom:8px;">
    <div style="background:#185FA5; color:#fff; font-size:14px; line-height:1.6; padding:10px 14px; border-radius:16px 16px 4px 16px; max-width:75%;">
      <%= @user_message.content %>
    </div>
  </div>
<% end %>

<%# 2. Append the AI response bubble to the message history %>
<%= turbo_stream.append "chat-messages-#{@chat.id}" do %>
  <div style="display:flex; justify-content:flex-start; gap:8px; align-items:flex-start; margin-bottom:8px;">
    <div style="width:28px; height:28px; background:#F0F1F8; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:13px;">✦</div>
    <div style="background:#F3F4F6; color:#1A1A2E; font-size:14px; line-height:1.6; padding:10px 14px; border-radius:16px 16px 16px 4px; max-width:75%;">
      <%= @ai_message.content %>
    </div>
  </div>
<% end %>

<%# 3. Clear the text input field %>
<%= turbo_stream.replace "chat-input-wrapper-#{@chat.id}" do %>
  <div id="chat-input-wrapper-<%= @chat.id %>">
    <%= form_with url: chat_messages_path(@chat), method: :post,
          data: { controller: "chat-form", action: "submit->chat-form#showLoader" },
          style: "display:flex; gap:8px; align-items:center;" do |f| %>
      <%= f.text_field :message,
            name: "message[content]",
            id: "chat-input-#{@chat.id}",
            placeholder: "Ask AI a question about this document...",
            autocomplete: "off",
            required: true,
            style: "flex:1; font-size:14px; padding:10px 14px; border:1px solid #E5E7EB; border-radius:24px; outline:none; background:#fff; color:#1A1A2E;" %>
      <%= f.submit "→",
            style: "width:38px; height:38px; background:#185FA5; color:#fff; border:none; border-radius:50%; font-size:18px; cursor:pointer; flex-shrink:0;" %>
    <% end %>
  </div>
<% end %>

<%# 4. Activate the expanded layout by adding the chat-active class to the page container %>
<%= turbo_stream.replace "chat-layout-container-#{@chat.id}" do %>
  <div id="chat-layout-container-<%= @chat.id %>" class="chat-active" style="margin-top:32px;">
    <%= render partial: "chats/chat_panel_inner", locals: { chat: @chat } %>
  </div>
<% end %>
